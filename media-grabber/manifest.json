{
  "manifest_version": 3,
  "name": "Media Grabber",
  "version": "2.2",
  "description": "Bulk media extraction and downloading from browser memory.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "mediagrabber@github.io"
    }
  }
}
